# ! adjust the `tree_url` in suggestion_params.json
# ! define some weights (e.g. BC, DE loop in VP1) in weights.json
# ! define the current nomenclature in aliases.json
# ! provide a genome annotation file in genome_annotation.gff3 -> or provide a list of proteins in suggestion_params.json

# what are the lineages?
LINEAGE = ["ev-d68", "ev-a71", "cva16"]  # Add more lineages as needed


rule all: # order: fetch > calculate_optimal_scales > suggest_new_clades
    input:
        expand("auspice/suggested_{lineage}.json", lineage=LINEAGE),
        expand("../virus_{lineage}/clades", lineage=LINEAGE),
        expand("../virus_{lineage}/.auto-generated/clades_{lineage}.md", lineage=LINEAGE)


TREE_PATH = "../../nextclade_{lineage}/results/auspice.json" # or TREE_PATH= None: use the URL from the config file
# TREE_PATH= None  # ⬆


# if not os.path.exists(GFF_FILE):
#     raise FileNotFoundError(f"GFF file not found: {GFF_FILE}")


rule fetch:
    output:
        tree = "auspice/original_{lineage}.json",
        annotation = "../virus_{lineage}/config/genome_annotation.gff3",
    params:
        lineage="{lineage}",
        tree_url=lambda wildcards: load_config(wildcards.lineage, "suggestion_params.json")["tree_url"],
    shell:
        """
        # Try Nextclade first
        echo "Attempting to fetch from Nextclade: enpen/enterovirus/{params.lineage}"
        if nextclade dataset get --name "enpen/enterovirus/{params.lineage}" --output-dir .nextclade_tmp 2>/dev/null; then
            if [[ -f ".nextclade_tmp/tree.json" ]]; then
                echo "✓ Success: Got tree from Nextclade"
                cp .nextclade_tmp/tree.json "{output.tree}"
                if [[ -f ".nextclade_tmp/genome_annotation.gff3" ]]; then
                    cp .nextclade_tmp/genome_annotation.gff3 {output.annotation}
                    echo "✓ Got annotation from Nextclade"
                fi
                rm -rf .nextclade_tmp
                exit 0
            fi
        fi
            
        # Fallback to Nextstrain
        echo "✗ Nextclade not available, falling back to Nextstrain"
        curl "{params.tree_url}" -o "{output.tree}" --max-time 10 -A "Mozilla/5.0"
        if [[ ! -f "{output.tree}" ]]; then
            echo "✗ Failed to fetch tree from Nextstrain"
            exit 1
        fi
        echo "✓ Success: Got tree from Nextstrain"

        # Extract genome_annotations from auspice.json and convert to GFF3
        seqid=$(jq -r '.meta.genome_annotations.nuc.seqid' "{output.tree}" | sed 's|.*/||;s|\.gb||')
        seq_start=$(jq -r '.meta.genome_annotations.nuc.start' "{output.tree}")
        seq_end=$(jq -r '.meta.genome_annotations.nuc.end' "{output.tree}")
        
        (
            echo "##gff-version 3"
            echo "#!gff-spec-version 1.21"
            echo "##sequence-region $seqid $seq_start $seq_end"
            jq -r '.meta.genome_annotations | to_entries[] | 
            "\\(.value.seqid)\\t.\\t\\(.value.type)\\t\\(.value.start)\\t\\(.value.end)\\t.\\t\\(.value.strand)\\t.\\tID=\\(.key);Name=\\(.key)"' \
            "{output.tree}"
        ) > "{output.annotation}"
            
        echo "✓ Generated GFF3 from tree metadata"
        """

rule calculate_optimal_scales:
    input: # define config paths
        tree = rules.fetch.output.tree, 
        weights = "../virus_{lineage}/config/weights.json", 
    output:
        scales = "../virus_{lineage}/config/optimal_scales.json"

    params:
        clade_key=lambda wildcards: "--clade-key subclade" if re.search(r"(NA|HA)", wildcards.lineage) else ""
    shell:
        """
        python3 scripts/calculate_optimal_scales.py \
            --tree {input.tree} \
            {params.clade_key} \
            --weights {input.weights} \
            --output {output.scales}
        """

rule suggest_new_clades:
    input: # define config paths
        tree = ancient(rules.fetch.output.tree),
        weights = "../virus_{lineage}/config/weights.json",
        aliases = "../virus_{lineage}/config/aliases.json",
        params = "../virus_{lineage}/config/suggestion_params.json",
        optimal = rules.calculate_optimal_scales.output.scales,
        
    params:
        clade = "../virus_{lineage}/new-clades.tsv",
        gff = lambda wildcards: f"--gff ../virus_{wildcards.lineage}/config/genome_annotation.gff3" if os.path.exists(f"../virus_{wildcards.lineage}/config/genome_annotation.gff3") else "",    
        clade_key=lambda wildcards: "--clade-key subclade" if re.search(r"(NA|HA)", wildcards.lineage) else "", # flu has different key for clades
        
        ## params for the plots
        plots = "False",  # "True" to generate plots
        cutoff = [round(x, 1) for x in np.arange(0.5, 1.5, 0.1)],
        div_add = [round(x, 2) for x in np.arange(0.5, 1.2, 0.2)],
        min_size = [round(x, 1) for x in np.arange(10, 40, 10)],
        bush_scale = lambda wildcards: load_config(wildcards.lineage, "optimal_scales.json")["optimal_scales"].get("bushiness_branch_scale"), #[5,10,100],
        bls_range = lambda wildcards: load_config(wildcards.lineage, "optimal_scales.json")["optimal_scales"].get("branch_length_scale"), #[2,10,20],
        div_scale = lambda wildcards: load_config(wildcards.lineage, "optimal_scales.json")["optimal_scales"].get("divergence_scale"), #[0.1, 1, 5, 10, 20],
    
    output:
        tree = "auspice/suggested_{lineage}.json"
    shell:
        """
        if [ -n "{params.gff}" ]; then 
            echo "{params.gff}"; 
        else 
            echo "No GFF file provided - Attention the divergence scale will be calculated based on nucleotides only"; 
        fi
        python3 scripts/add_new_clades.py \
            --tree {input.tree} \
            --config {input.params} \
            --aliases {input.aliases} \
            --weights {input.weights} \
            --clades {params.clade} \
            --output {output.tree} \
            {params.gff} \
            {params.clade_key} \
            \
            --plots {params.plots} \
            --cutoff {params.cutoff} \
            --div_add {params.div_add} \
            --div_scale {params.div_scale} \
            --min_size {params.min_size} \
            --bush_scale {params.bush_scale} \
            --bls_range {params.bls_range}
        
        """ #

        # visualize: http://localhost:4000/suggested/D68?branchLabel=new-clade&c=new-clade&d=tree&p=full&tl=__strain__


rule visualization:
    input:
        clades = "../virus_{lineage}/new-clades_all.tsv",
        tree = rules.suggest_new_clades.output.tree,
        d = "../virus_{lineage}/plots/",
        params = "../virus_{lineage}/config/suggestion_params.json",
    params:
        color = "True",
        grid = "../virus_{lineage}/plots/clade_table_names.tiff"

    output:
        tiff = "../virus_{lineage}/plots/violin_plots.tiff",
    shell:
        """
        Rscript scripts/visualize_clades.R --clades {input.clades} --tree {input.tree} \
        --dir-out {input.d} --params {input.params} --out {output.tiff} --grid {params.grid} --color {params.color}
        """


rule extract_clade_ymls:
    input:
        json = rules.suggest_new_clades.output.tree,
    output:
        clades = directory("../virus_{lineage}/clades"),
    shell:
        """
        python3 scripts/extract_yml_from_json.py \
            --json {input.json} \
            --outdir {output.clades}
        """

# generate the markdown summary of the clade definitions
rule summary:
    input:
        expand("clades/{file}", file=glob_wildcards("clades/{file}").file),
        clades = rules.extract_clade_ymls.output.clades,
    output:
        md = "../virus_{lineage}/.auto-generated/clades_{lineage}.md", #".auto-generated/subclades_D68.md"
        
    shell:
        """
        python3 scripts/generate_markdown_summary.py \
            --input-dir {input.clades} --lineage {wildcards.lineage} --file {output.md}
        """

rule construct_tsv:
    input:
        "../virus_{lineage}/clades"
    output:
        tsv = "../virus_{lineage}/.auto-generated/subclades.tsv",
        ptsv = "../virus_{lineage}/.auto-generated/subclade-proposals.tsv",
        clades = "../virus_{lineage}/.auto-generated/clades.tsv",
        clades_long = "../virus_{lineage}/.auto-generated/clades-long.tsv"
    shell:
        """
        python3 scripts/construct_tsv.py --input-dir {input} --output-tsv {output.tsv}
        python3 scripts/construct_tsv.py --input-dir {input} subclade-proposals --output-tsv {output.ptsv}
        python3 scripts/construct_tsv.py --input-dir {input} --aux-input-dir subclades --flat-output --use-short-name --output-tsv {output.clades}
        python3 scripts/construct_tsv.py --input-dir {input} --aux-input-dir subclades --flat-output --output-tsv {output.clades_long}
        """

rule clean:
    shell:
        """
        rm -r ../*/.auto-generated \
        ../*/clades/ \
        ../*/subclades.tex \
        auspice/*
        """